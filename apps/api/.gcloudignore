# apps/api/.gcloudignore
# Keep in sync with .dockerignore — both files should have the same ignore
# rules so Cloud Build uploads and Docker builds exclude identical paths.

########################################
# OS & Editor
########################################
.DS_Store
Thumbs.db
.idea/
.vscode/
*.code-workspace

########################################
# Node / TypeScript / Frontend
########################################
node_modules/
dist/
build/
out/
.next/
.nuxt/
.vercel/
.turbo/
.cache/
.parcel-cache/
.eslintcache
.stylelintcache
*.tsbuildinfo

# Package manager logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Yarn 2+ (Berry)
.yarn/*
!.yarn/releases
!.yarn/plugins
!.yarn/sdks
!.yarn/versions

########################################
# Python / Backend
########################################
__pycache__/
*.py[cod]
*$py.class

# Virtual environments & tests
.venv/
venv/
ENV/
.conda/
.python-version
tests/

# Packaging / build artifacts
build/
dist/
*.egg-info/
.eggs/
pip-wheel-metadata/

# Type checking / tooling caches
.mypy_cache/
.pytest_cache/
.ruff_cache/
.pyre/
.pytype/
.nox/
.tox/

# Coverage / reports (both py and js)
coverage/
.coverage
.coverage.*
coverage.xml
htmlcov/
.nyc_output/
lcov.info

# Jupyter
.ipynb_checkpoints

########################################
# Environment & Secrets
########################################
.env
.env.*
!.env.example
!.env.*.example

# Local development environment overrides
local-env/

########################################
# Terraform (keep lockfile)
########################################
.terraform/
**/.terraform/*
*.tfstate
*.tfstate.*
crash.log
crash.*.log
*.tfvars
*.tfvars.json
override.tf
override.tf.json
*_override.tf
*_override.tf.json
!.terraform.lock.hcl

########################################
# Misc logs
########################################
logs/
*.log
log/
