# apps/api/.env.example
#
# Local development defaults. Copy this file to .env and replace every
# "not-a-secret" value before using it outside local development.

# Runtime
PORT=8080
PYTHONUNBUFFERED=1

# App
APP_NAME="Praxis Agents OS"
APP_VERSION=1.0.0
ALLOW_SIGNUP=true
ALLOW_WORKSPACE_CREATION=true
ENVIRONMENT=local
DEBUG=true
SQL_DEBUG=false
LOG_LEVEL=INFO

# URLs and CORS
APP_BASE_URL=http://localhost:8000
API_V1_PREFIX=/api/v1
ALLOWED_CORS_ORIGINS=http://localhost:3000
FRONTEND_URL=http://localhost:3000
NEXTJS_INTERNAL_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/postgres
IVFFLAT_PROBES=10

# Security
# Generate a production value with:
# python3 -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=not-a-secret-local-development-secret-key-change-me

# Generate a production value with:
# python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=bm90LWEtc2VjcmV0LWxvY2FsLWRldi1rZXktMDAwMDA=

SUPER_ADMIN_EMAILS=
SESSION_DURATION_DAYS=7
SECURE_COOKIES=false
COOKIE_DOMAIN=
MAX_REQUEST_BODY_BYTES=10485760
INTERNAL_SCHEDULE_TRIGGER_SECRET=
SECURITY_LOCKOUT_DURATION_MINUTES=60
SECURITY_SUSPICIOUS_ACTIVITY_THRESHOLD=10
PASSWORD_RESET_TOKEN_TTL_MINUTES=60

# Providers
CLOUD_PROVIDER=local
# local | gcp_secret_manager | azure_key_vault | aws_secrets_manager
SECRET_PROVIDER=local
STORAGE_PROVIDER=local_fs
EMAIL_PROVIDER=console
LOCAL_STORAGE_ROOT=.local/storage

# Integration packages are enabled through this single JSON allowlist.
INTEGRATIONS_ENABLED_PROVIDERS=[]
INTEGRATIONS_TOKEN_REFRESH_LEEWAY_SECONDS=120
INTEGRATIONS_HTTP_TIMEOUT_SECONDS=30
INTEGRATIONS_HTTP_RETRY_MAX_ATTEMPTS=3
INTEGRATIONS_HTTP_RETRY_BACKOFF_FACTOR=0.5
INTEGRATIONS_HTTP_RETRY_AFTER_CAP_SECONDS=60
CREDENTIAL_MASTER_KEY_SECRET_NAME=credential-master-key
# Local-only development root. `make bootstrap` generates a unique value in
# active local env files; production resolves the named secret above.

# Rate limits
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_REQUESTS_PER_HOUR=1000
RATE_LIMIT_LOGIN_ATTEMPTS_PER_HOUR=5
RATE_LIMIT_REGISTRATION_PER_DAY=3
RATE_LIMIT_PASSWORD_RESET_PER_DAY=3
TRUSTED_PROXY_CIDRS=127.0.0.1/32,::1/128

# Auth
EMAIL_AUTH_ENABLED=true
OAUTH_REQUEST_TIMEOUT=30
OAUTH_MAX_RETRIES=3
OAUTH_BACKOFF_FACTOR=0.5

# OAuth providers
# Each enabled provider redirect URI must exactly equal the web origin plus
# /oauth/callback. Local example: http://localhost:3000/oauth/callback
GOOGLE_OAUTH_ENABLED=false
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=
GITHUB_OAUTH_ENABLED=false
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=
MICROSOFT_OAUTH_ENABLED=false
MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=
MICROSOFT_OAUTH_REDIRECT_URI=

# LLM models and providers
# The model catalog is hard-coded in services/agents/models/registry.py; these only
# pick defaults and hold credentials. Set the keys backing your active providers
# (required in production for the default and conversation-naming providers).
DEFAULT_MODEL_PROVIDER=openai
DEFAULT_MODEL=gpt-5.4-mini
CONVERSATION_NAMING_PROVIDER=openai
CONVERSATION_NAMING_MODEL=gpt-5.4-nano
NATIVE_WEB_SEARCH_MAX_STEPS=3
AGENT_SCHEDULE_WORKER_POLL_SECONDS=5.0
AGENT_SCHEDULE_WORKER_BATCH_SIZE=25
AGENT_SCHEDULE_RUN_CLAIM_TTL_SECONDS=300
AGENT_SCHEDULE_RUN_MAX_ATTEMPTS=3
AGENT_SCHEDULE_WORKER_SHUTDOWN_SECONDS=30.0
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
# Google Vertex AI: alternative to GOOGLE_API_KEY. Uses Application Default
# Credentials and needs a project (falls back to GCP_PROJECT_ID below).
GOOGLE_VERTEX_AI=false
GOOGLE_VERTEX_PROJECT=
GOOGLE_VERTEX_LOCATION=global
# Azure OpenAI is deployment-based; the deployment name comes from the agent row.
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=2024-10-21

# Agent tracing / OpenTelemetry
# Disabled by default. When enabled, spans omit prompts, completions, tool arguments, and binary content unless AGENT_TRACING_INCLUDE_CONTENT=true.
AGENT_TRACING_ENABLED=false
AGENT_TRACING_INCLUDE_CONTENT=false
AGENT_TRACING_ALLOW_CONTENT_IN_PRODUCTION=false

# Local/cloud asset storage
# Cloud SDKs are bundled by provider. Local dev needs no cloud extra; production
# images should build with CLOUD_EXTRA=gcp, aws, or azure to match the deployment.
GCP_PROJECT_ID=
GCS_PUBLIC_ASSETS_BUCKET=
GCS_PRIVATE_ASSETS_BUCKET=
PUBLIC_ASSETS_BASE_URL=
PUBLIC_ASSETS_CACHE_CONTROL="public, max-age=31536000, immutable"
S3_PUBLIC_ASSETS_BUCKET=
S3_PRIVATE_ASSETS_BUCKET=
AWS_REGION=
EMAIL_ENABLED=true
EMAIL_FROM_NAME=Praxis
EMAIL_REPLY_TO=noreply@praxis-agents.ai
SES_REGION=eu-west-2
SES_FROM_EMAIL=noreply@praxis-agents.ai
SES_CONFIGURATION_SET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AZURE_STORAGE_ACCOUNT_NAME=
AZURE_STORAGE_PUBLIC_CONTAINER=
AZURE_STORAGE_PRIVATE_CONTAINER=
AZURE_STORAGE_ACCOUNT_URL=
AZURE_MANAGED_IDENTITY_CLIENT_ID=
# Azure signed URLs use user delegation keys. The runtime identity needs the Microsoft.Storage/storageAccounts/blobServices/generateUserDelegationKey action (for example through Storage Blob Delegator plus data access to the containers).
AZURE_KEY_VAULT_URL=

# Upload limits
MAX_FILE_SIZE_AVATAR=5242880
MAX_FILE_SIZE_ICON=2097152
MAX_FILE_SIZE_DOCUMENT=52428800
MAX_FILE_SIZE_AGENT_FILE=104857600
MAX_FILE_SIZE_IMAGE=10485760
MAX_FILE_SIZE_VIDEO=104857600
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp
ALLOWED_ICON_TYPES=image/jpeg,image/png,image/webp
ALLOWED_DOCUMENT_TYPES=application/pdf,application/vnd.openxmlformats-officedocument.wordprocessingml.document,text/plain,text/markdown
ALLOWED_VIDEO_TYPES=video/mp4
ENABLE_IMAGE_PROCESSING=true
AVATAR_SIZE=512
ICON_SIZE=256
THUMBNAIL_SIZES=128,256
